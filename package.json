    "fast-mode",
    "fast",
    "openai",
    "codex",
    "footer",
    "statusline"
  ],
  "author": "Matthias Vallentin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mavam/pi-service-tier.git"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "test": "node --test --experimental-strip-types *.test.ts"
